# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://ragsearch-123.search.windows.net
AZURE_SEARCH_INDEX=rag-index

# Azure Tenant ID (required for Microsoft corporate accounts)
# Find it: Azure Portal -> Microsoft Entra ID -> Overview -> Tenant ID
AZURE_TENANT_ID=16b3c013-d300-468d-ac64-7eda0820b6d3

# Azure Blob Storage Configuration
AZURE_STORAGE_ACCOUNT_URL=https://ragstrorage.blob.core.windows.net
AZURE_STORAGE_CONTAINER=raw-docs
AZURE_STORAGE_PREFIX=

# Local Embedding Model (sentence-transformers)
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Hugging Face offline mode (use cached models only)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Chunking Configuration
CHUNK_SIZE_CHARS=1500
CHUNK_OVERLAP_CHARS=200

# Query Configuration
TOP_K=5

AZURE_AI_PROJECT_ENDPOINT=https://rag-system-showcase-resource.services.ai.azure.com/api/projects/rag-system-showcase
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.3-chat
AZURE_USE_EXPLICIT_TENANT=true

# Retrieval Improvements
ENABLE_QUERY_TRANSFORMS=false
ENABLE_RERANKER=false
ENABLE_LLM=true
LLM_MODEL_DEPLOYMENT_NAME=gpt-5.3-chat
MAX_CONTEXT_CHARS=12000
NUM_QUERY_EXPANSIONS=3
NUM_SUB_QUERIES=3
TOP_K_RETRIEVE=30
TOP_K_FINAL=5